<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="001-create-billing-schema" author="echindr">
        <sql>CREATE SCHEMA IF NOT EXISTS billing;</sql>
    </changeSet>

    <changeSet id="002-create-call_data_record-table" author="echindr">
        <createTable tableName="call_data_record" schemaName="billing">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="price" type="DOUBLE PRECISION">
                <constraints nullable="false"/>
            </column>
            <column name="quantity" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="003-add-ulid-as-primary-key" author="echindr">
        <!-- Add ulid column -->
        <addColumn tableName="call_data_record" schemaName="billing">
            <column name="ulid" type="VARCHAR(26)">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <!-- Drop old primary key constraint (usually named call_data_record_pkey in postgres) -->
        <dropPrimaryKey tableName="call_data_record" schemaName="billing"/>

        <!-- Drop old id column -->
        <dropColumn tableName="call_data_record" schemaName="billing" columnName="id"/>

        <!-- Add new primary key constraint on ulid -->
        <addPrimaryKey tableName="call_data_record" schemaName="billing" columnNames="ulid" constraintName="pk_call_data_record"/>
    </changeSet>

</databaseChangeLog>
